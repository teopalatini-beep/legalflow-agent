# Required for enterprise-protected endpoints
LEGALFLOW_SSO_TOKEN=replace-with-long-random-token

# Required only when using SDK mode
CURSOR_API_KEY=cursor_xxx

# Optional real e-sign integration (if unset, simulation fallback is used)
LEGALFLOW_ESIGN_ENDPOINT=https://your-esign-provider.example/api/signature
LEGALFLOW_ESIGN_API_KEY=your_esign_api_key
LEGALFLOW_ESIGN_WEBHOOK_SECRET=your_esign_webhook_secret
LEGALFLOW_APP_BASE_URL=http://localhost:8000
